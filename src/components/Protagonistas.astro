---
// src/components/Protagonistas.astro

interface Protagonistas {
  novios: { nombre: string }[];
  padresNovio?: { nombre: string }[];
  padresNovia?: { nombre: string }[];
  madreNovia?: { nombre: string }[];
  padreNovia?: { nombre: string }[];
  padrinos?: { nombre: string }[];
  // Agrega más roles según necesites
}

interface Props {
  frase?: string;
  pilares?: string[];
  protagonistas: Protagonistas;
}

const {
  frase = "Dos almas se conocen, se enamoran, se eligen y se unen, siendo su destino una aventura inolvidable; Nos casaremos, construyendo nuestra relación sobre los pilares:",
  pilares = ["Amor", "Respeto", "Confianza", "Compromiso"],
  protagonistas,
} = Astro.props;

// Construye las cards dinámicamente
const cards = [
  protagonistas.novios?.length         && { rol: "Novios",            personas: protagonistas.novios },
  protagonistas.padresNovio?.length    && { rol: "Padres del Novio",  personas: protagonistas.padresNovio },
  protagonistas.padresNovia?.length    && { rol: "Padres de la Novia",personas: protagonistas.padresNovia },
  protagonistas.madreNovia?.length     && { rol: "Madre de la Novia", personas: protagonistas.madreNovia },
  protagonistas.padreNovia?.length     && { rol: "Padre de la Novia", personas: protagonistas.padreNovia },
  protagonistas.padrinos?.length       && { rol: "Padrinos",          personas: protagonistas.padrinos },
].filter(Boolean) as { rol: string; personas: { nombre: string }[] }[];
---

<section id="protagonistas" class="w-full pb-28 px-6 bg-white flex flex-col items-center gap-20 relative overflow-hidden">

  <!-- Detalles decorativos -->
  <svg class="absolute top-0 right-0 w-64 opacity-5 pointer-events-none" viewBox="0 0 200 200" fill="none">
    <circle cx="200" cy="0" r="80"  stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="200" cy="0" r="120" stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="200" cy="0" r="160" stroke="#4a7ab5" stroke-width="1"/>
  </svg>
  <svg class="absolute bottom-0 left-0 w-64 opacity-5 pointer-events-none" viewBox="0 0 200 200" fill="none">
    <circle cx="0" cy="200" r="80"  stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="200" r="120" stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="200" r="160" stroke="#4a7ab5" stroke-width="1"/>
  </svg>

  <!-- ── FRASE ─────────────────────────────────────── -->
  <div class="prot-item relative z-10 max-w-2xl w-full flex flex-col items-center gap-8 text-center">

    <div class="flex items-center gap-4">
      <div class="w-9 h-px bg-blue-400/35"></div>
      <span class="font-[Jost] text-[0.58rem] tracking-[0.35em] uppercase text-blue-950/40">Nuestro camino</span>
      <div class="w-9 h-px bg-blue-400/35"></div>
    </div>

    <svg width="40" height="30" viewBox="0 0 40 30" fill="none" class="opacity-15">
      <path d="M0 30 C0 18 6 8 18 0 L22 4 C14 10 10 18 12 30 Z" fill="#4a7ab5"/>
      <path d="M22 30 C22 18 28 8 40 0 L44 4 C36 10 32 18 34 30 Z" fill="#4a7ab5"/>
    </svg>

    <p class="font-[Cormorant_Garamond] text-xl md:text-2xl italic text-blue-950/70 leading-loose font-light">
      {frase}
    </p>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 mt-2">
      {pilares.map(p => (
        <div class="flex items-center gap-2">
          <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
          <span class="font-[Jost] text-[0.62rem] tracking-[0.25em] uppercase text-blue-500 font-medium">{p}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Divisor -->
  <div class="prot-item relative z-10 flex items-center gap-6 w-full max-w-lg">
    <div class="flex-1 h-px bg-gradient-to-r from-transparent to-blue-300/25"></div>
    <svg viewBox="0 0 24 24" width="18" fill="none" stroke="#4a7ab5" stroke-width="1" class="opacity-40">
      <path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z"/>
    </svg>
    <div class="flex-1 h-px bg-gradient-to-l from-transparent to-blue-300/25"></div>
  </div>

  <!-- ── CARDS DINÁMICAS ────────────────────────────── -->
  <div class="prot-item relative z-10 w-full max-w-5xl flex flex-wrap justify-center gap-6">
    {cards.map(card => (
      <div class="flex flex-col items-center text-center gap-3 p-8 bg-blue-50/60 border border-blue-200/30 rounded hover:shadow-lg hover:-translate-y-1 transition-all duration-300 min-w-[160px]">
        <div class="w-7 h-0.5 bg-blue-500 rounded mb-1"></div>
        <p class="font-[Jost] text-[0.55rem] tracking-[0.3em] uppercase text-blue-500 font-medium">
          {card.rol}
        </p>
        {card.personas.map((persona, i) => (
          <>
            {i > 0 && <div class="w-5 h-px bg-blue-300/40"></div>}
            <p class="font-[Cormorant_Garamond] text-lg italic text-blue-950 leading-snug">
              {persona.nombre.split(' ').slice(0, 2).join(' ')}<br/>
              {persona.nombre.split(' ').slice(2).join(' ')}
            </p>
          </>
        ))}
      </div>
    ))}
  </div>

</section>

<style>
  .prot-item {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .prot-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const protItems = document.querySelectorAll('.prot-item');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 150);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });

  protItems.forEach(el => obs.observe(el));
</script>