---
type TipoRegalo = "libre" | "sobres" | "ambos";

interface Props {
  tipoRegalo: TipoRegalo;
  cuentaBancaria?: {
    banco: string;
    titular: string;
    cuenta: string;
    clabe?: string;
  };
}

const { tipoRegalo, cuentaBancaria } = Astro.props;
---

<section id="regalos" class="w-full py-28 px-6 bg-[#f0f4fa] flex flex-col items-center gap-12 relative overflow-hidden">

  <svg class="absolute bottom-0 left-0 w-64 opacity-5 pointer-events-none" viewBox="0 0 200 200" fill="none">
    <circle cx="0" cy="200" r="80"  stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="200" r="120" stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="200" r="160" stroke="#4a7ab5" stroke-width="1"/>
  </svg>

  <div class="reg-item flex flex-col items-center gap-4 text-center z-10">
    <div class="flex items-center gap-4">
      <div class="w-9 h-px bg-blue-400/35"></div>
      <span class="font-[Jost] text-[0.58rem] tracking-[0.35em] uppercase text-blue-950/40">Con cariño</span>
      <div class="w-9 h-px bg-blue-400/35"></div>
    </div>
    <h2 class="font-[Cormorant_Garamond] text-[clamp(2rem,5vw,3rem)] italic text-blue-950 font-normal">
      Mesa de Regalos
    </h2>
    <p class="font-[Cormorant_Garamond] text-lg italic text-blue-950/60 font-light max-w-md">
      Tu presencia es nuestro mejor regalo. Si deseas obsequiarnos algo, aquí nuestras opciones:
    </p>
  </div>

  <div class="reg-item z-10 w-full max-w-2xl flex flex-col sm:flex-row gap-6 justify-center">

    {(tipoRegalo === "libre" || tipoRegalo === "ambos") && (
      <div class="flex-1 flex flex-col items-center gap-5 p-8 bg-white border border-blue-100 rounded text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <svg viewBox="0 0 64 64" class="w-16 h-16" fill="none" stroke="#4a7ab5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="10" y="28" width="44" height="28" rx="1"/>
          <rect x="8"  y="20" width="48" height="10" rx="1"/>
          <line x1="32" y1="20" x2="32" y2="56"/>
          <path d="M32 20 C32 20 24 18 20 12 C18 8 20 4 24 6 C28 8 32 20 32 20Z"/>
          <path d="M32 20 C32 20 40 18 44 12 C46 8 44 4 40 6 C36 8 32 20 32 20Z"/>
        </svg>
        <div>
          <p class="font-[Jost] text-[0.58rem] tracking-[0.3em] uppercase text-blue-500 font-medium mb-2">Regalo Libre</p>
          <p class="font-[Cormorant_Garamond] text-base italic text-blue-950/60 leading-relaxed">
            Elige el regalo que más se acomode a ti. Con cariño recibiremos lo que venga de tu corazón.
          </p>
        </div>
      </div>
    )}

    {(tipoRegalo === "sobres" || tipoRegalo === "ambos") && (
      <div class="flex-1 flex flex-col items-center gap-5 p-8 bg-white border border-blue-100 rounded text-center hover:shadow-md hover:-translate-y-1 transition-all duration-300">
        <svg viewBox="0 0 64 64" class="w-16 h-16" fill="none" stroke="#4a7ab5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="8" y="16" width="48" height="34" rx="2"/>
          <path d="M8 16 L32 36 L56 16"/>
          <path d="M8 50 L24 34"/>
          <path d="M56 50 L40 34"/>
          <rect x="22" y="6" width="20" height="12" rx="1"/>
          <line x1="26" y1="10" x2="38" y2="10"/>
          <line x1="26" y1="13" x2="34" y2="13"/>
        </svg>
        <div>
          <p class="font-[Jost] text-[0.58rem] tracking-[0.3em] uppercase text-blue-500 font-medium mb-2">Lluvia de Sobres</p>
          <p class="font-[Cormorant_Garamond] text-base italic text-blue-950/60 leading-relaxed">
            Si prefieres hacernos un obsequio en efectivo, con mucho amor lo recibiremos.
          </p>
          {cuentaBancaria && (
            <div class="mt-4 p-4 bg-blue-50 rounded border border-blue-100 text-left flex flex-col gap-1">
              <p class="font-[Jost] text-[0.55rem] tracking-[0.2em] uppercase text-blue-400 mb-1">Transferencia</p>
              <p class="font-[Jost] text-xs text-blue-950/70"><span class="text-blue-950/40">Banco: </span>{cuentaBancaria.banco}</p>
              <p class="font-[Jost] text-xs text-blue-950/70"><span class="text-blue-950/40">Titular: </span>{cuentaBancaria.titular}</p>
              <p class="font-[Jost] text-xs text-blue-950/70"><span class="text-blue-950/40">Cuenta: </span>{cuentaBancaria.cuenta}</p>
              {cuentaBancaria.clabe && (
                <p class="font-[Jost] text-xs text-blue-950/70"><span class="text-blue-950/40">CLABE: </span>{cuentaBancaria.clabe}</p>
              )}
            </div>
          )}
        </div>
      </div>
    )}

  </div>

</section>

<style>
  .reg-item {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reg-item.visible { opacity: 1; transform: translateY(0); }
</style>

<script>
  const els = document.querySelectorAll('.reg-item');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 120);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  els.forEach(el => obs.observe(el));
</script>