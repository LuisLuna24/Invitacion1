---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';

const novia = "Viridiana";
const novio = "Alexis";

const dia = 15;
const mes = "Nov";
const anio = 2026;

---

  <section id="hero" style="
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #e8f0fa 0%, #f0f4fa 40%, #dce8f5 70%, #c8ddf0 100%);
    padding: 3rem 1.5rem 4rem;
  ">

    <!-- Círculos decorativos de fondo -->
    <div style="
      position: absolute; top: -10%; right: -10%;
      width: 500px; height: 500px; border-radius: 50%;
      background: radial-gradient(circle, rgba(74,122,181,0.08) 0%, transparent 70%);
      pointer-events: none;
    "></div>
    <div style="
      position: absolute; bottom: -5%; left: -8%;
      width: 400px; height: 400px; border-radius: 50%;
      background: radial-gradient(circle, rgba(74,122,181,0.06) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <!-- Línea decorativa top -->
    <div class="hero-item" style="display:flex;align-items:center;gap:1rem;margin-bottom:2rem;">
      <div style="width:40px;height:1px;background:rgba(74,122,181,0.4);"></div>
      <span style="font-family:'Jost',sans-serif;font-size:0.6rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(13,36,72,0.45);">Save the date</span>
      <div style="width:40px;height:1px;background:rgba(74,122,181,0.4);"></div>
    </div>

    <!-- Nombres -->
    <h1 class="hero-item" style="
      font-family:'Cormorant Garamond',serif;
      font-size: clamp(3rem, 10vw, 7rem);
      font-style: italic;
      color: #0d2448;
      letter-spacing: 0.02em;
      text-align: center;
      line-height: 1.1;
      margin-bottom: 1.5rem;
    ">
      {novia} <span style="color:#4a7ab5;">&</spadianan> {novio}
    </h1>

    <!-- Foto de los novios -->
    <div class="hero-item" style="
      width: clamp(180px, 40vw, 280px);
      aspect-ratio: 3/4;
      border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
      overflow: hidden;
      border: 3px solid rgba(74,122,181,0.25);
      box-shadow: 0 20px 60px rgba(13,36,72,0.12), 0 0 0 8px rgba(74,122,181,0.06);
      margin-bottom: 2.5rem;
      position: relative;
    ">
      <!-- Reemplaza /images/novios.jpg con tu foto -->
      <img 
        src="/images/novios.jpg" 
        alt="Viridiana & Alexis"
        style="width:100%;height:100%;object-fit:cover;object-position:center top;"
        onerror="this.parentElement.style.background='linear-gradient(160deg,#c8ddf0,#7aaad4)';this.style.display='none';"
      />
      <!-- Overlay sutil -->
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 60%,rgba(13,36,72,0.08));"></div>
    </div>

    <!-- Fecha -->
    <div class="hero-item" style="
      display: flex;
      align-items: center;
      gap: 1.5rem;
      margin-bottom: 3rem;
    ">
      <div style="text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;color:#0d2448;line-height:1;">{dia}</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.5);">Día</p>
      </div>
      <div style="width:1px;height:40px;background:rgba(74,122,181,0.3);"></div>
      <div style="text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;color:#4a7ab5;line-height:1;">{mes}</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.5);">Mes</p>
      </div>
      <div style="width:1px;height:40px;background:rgba(74,122,181,0.3);"></div>
      <div style="text-align:center;">
        <p style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:300;color:#0d2448;line-height:1;">{anio}</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.5);">Año</p>
      </div>
    </div>

    <!-- Cuenta regresiva -->
    <div class="hero-item" style="
      background: rgba(255,255,255,0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(74,122,181,0.15);
      border-radius: 4px;
      padding: 1.5rem 2.5rem;
      display: flex;
      gap: 2rem;
      align-items: center;
      box-shadow: 0 4px 24px rgba(13,36,72,0.06);
    ">
      <div style="text-align:center;">
        <p id="cd-dias" style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;color:#0d2448;line-height:1;min-width:2ch;text-align:center;">--</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.45);margin-top:4px;">Días</p>
      </div>
      <div style="width:1px;height:32px;background:rgba(74,122,181,0.2);"></div>
      <div style="text-align:center;">
        <p id="cd-horas" style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;color:#0d2448;line-height:1;min-width:2ch;text-align:center;">--</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.45);margin-top:4px;">Horas</p>
      </div>
      <div style="width:1px;height:32px;background:rgba(74,122,181,0.2);"></div>
      <div style="text-align:center;">
        <p id="cd-min" style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;color:#0d2448;line-height:1;min-width:2ch;text-align:center;">--</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.45);margin-top:4px;">Min</p>
      </div>
      <div style="width:1px;height:32px;background:rgba(74,122,181,0.2);"></div>
      <div style="text-align:center;">
        <p id="cd-seg" style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;color:#0d2448;line-height:1;min-width:2ch;text-align:center;">--</p>
        <p style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:rgba(13,36,72,0.45);margin-top:4px;">Seg</p>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="hero-item" style="margin-top:3rem;display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
      <span style="font-family:'Jost',sans-serif;font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:rgba(13,36,72,0.35);">Descubre más</span>
      <div id="scroll-arrow" style="width:1px;height:32px;background:linear-gradient(to bottom,rgba(74,122,181,0.5),transparent);"></div>
    </div>

  </section>

  <style>
  /* Fade in escalonado */
  .hero-item {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFade 0.9s ease forwards;
  }
  .hero-item:nth-child(1) { animation-delay: 0.1s; }
  .hero-item:nth-child(2) { animation-delay: 0.25s; }
  .hero-item:nth-child(3) { animation-delay: 0.45s; }
  .hero-item:nth-child(4) { animation-delay: 0.65s; }
  .hero-item:nth-child(5) { animation-delay: 0.85s; }
  .hero-item:nth-child(6) { animation-delay: 1.0s; }

  @keyframes heroFade {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Flecha pulsante */
  #scroll-arrow {
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50%       { opacity: 1;   transform: scaleY(1.3); }
  }
</style>

<script>
  // ── Cuenta regresiva ─────────────────────────────
  // Cambia esta fecha por la real de la boda
  const bodaDate = new Date('2026-07-15T15:40:00');

  function update() {
    const now  = new Date();
    const diff = bodaDate.getTime() - now.getTime();

    if (diff <= 0) {
      document.getElementById('cd-dias')!.textContent  = '¡Hoy!';
      document.getElementById('cd-horas')!.textContent = '--';
      document.getElementById('cd-min')!.textContent   = '--';
      document.getElementById('cd-seg')!.textContent   = '--';
      return;
    }

    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000)  / 60000);
    const s = Math.floor((diff % 60000)    / 1000);

    document.getElementById('cd-dias')!.textContent  = String(d);
    document.getElementById('cd-horas')!.textContent = String(h).padStart(2,'0');
    document.getElementById('cd-min')!.textContent   = String(m).padStart(2,'0');
    document.getElementById('cd-seg')!.textContent   = String(s).padStart(2,'0');
  }

  update();
  setInterval(update, 1000);
</script>
