---
// src/components/Hero.astro

interface Props {
  novia: string;
  novio: string;
  dia: string;
  mes: string;
  anio: number;
  hora: string;         // hora de la boda para countdown "2026-07-04T15:45:00"
  fotoSrc?: string;
  fotoAlt?: string;
}

const {
  novia,
  novio,
  dia,
  mes,
  anio,
  hora,
  fotoSrc = "/images/novios.jpg",
  fotoAlt,
} = Astro.props;

const altText = fotoAlt ?? `${novia} & ${novio}`;
---

<section id="hero" class="w-full min-h-screen flex flex-col items-center justify-center relative overflow-hidden px-6 pt-6 pb-16"
  style="background: linear-gradient(160deg, #e8f0fa 0%, #f0f4fa 40%, #dce8f5 70%, #c8ddf0 100%);">

  <!-- Círculos decorativos -->
  <div class="absolute -top-[10%] -right-[10%] w-[500px] h-[500px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(74,122,181,0.08) 0%, transparent 70%);"></div>
  <div class="absolute -bottom-[5%] -left-[8%] w-[400px] h-[400px] rounded-full pointer-events-none"
    style="background: radial-gradient(circle, rgba(74,122,181,0.06) 0%, transparent 70%);"></div>

  <!-- Save the date -->
  <div class="hero-item flex items-center gap-4 mb-8">
    <div class="w-10 h-px bg-blue-400/40"></div>
    <span class="font-[Jost] text-[0.6rem] tracking-[0.35em] uppercase text-blue-950/45">Save the date</span>
    <div class="w-10 h-px bg-blue-400/40"></div>
  </div>

  <!-- Nombres -->
  <h1 class="hero-item font-[Cormorant_Garamond] italic text-blue-950 text-center leading-tight mb-6"
    style="font-size: clamp(3rem, 10vw, 7rem); letter-spacing: 0.02em;">
    {novia} <span class="text-blue-500">&</span> {novio}
  </h1>

  <!-- Foto -->
  <div class="hero-item mb-10 relative shrink-0"
    style="width: clamp(180px,40vw,280px); aspect-ratio:3/4; border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%; overflow:hidden; border: 3px solid rgba(74,122,181,0.25); box-shadow: 0 20px 60px rgba(13,36,72,0.12), 0 0 0 8px rgba(74,122,181,0.06);">
    <img
      src={fotoSrc}
      alt={altText}
      class="w-full h-full object-cover object-top"
      onerror="this.parentElement.style.background='linear-gradient(160deg,#c8ddf0,#7aaad4)';this.style.display='none';"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 60%, rgba(13,36,72,0.08));"></div>
  </div>

  <!-- Fecha -->
  <div class="hero-item flex items-center gap-6 mb-12">
    <div class="text-center">
      <p class="font-[Cormorant_Garamond] font-light text-blue-950 leading-none" style="font-size:2.5rem;">{dia}</p>
      <p class="font-[Jost] text-[0.55rem] tracking-[0.2em] uppercase text-blue-950/50 mt-1">Día</p>
    </div>
    <div class="w-px h-10 bg-blue-400/30"></div>
    <div class="text-center">
      <p class="font-[Cormorant_Garamond] font-light text-blue-500 leading-none" style="font-size:2.5rem;">{mes}</p>
      <p class="font-[Jost] text-[0.55rem] tracking-[0.2em] uppercase text-blue-950/50 mt-1">Mes</p>
    </div>
    <div class="w-px h-10 bg-blue-400/30"></div>
    <div class="text-center">
      <p class="font-[Cormorant_Garamond] font-light text-blue-950 leading-none" style="font-size:2.5rem;">{anio}</p>
      <p class="font-[Jost] text-[0.55rem] tracking-[0.2em] uppercase text-blue-950/50 mt-1">Año</p>
    </div>
  </div>

  <!-- Cuenta regresiva -->
  <div class="hero-item flex items-center gap-8 px-10 py-6 rounded"
    style="background:rgba(255,255,255,0.6); backdrop-filter:blur(12px); border:1px solid rgba(74,122,181,0.15); box-shadow:0 4px 24px rgba(13,36,72,0.06);">
    {[
      { id: "cd-dias",  label: "Días"  },
      { id: "cd-horas", label: "Horas" },
      { id: "cd-min",   label: "Min"   },
      { id: "cd-seg",   label: "Seg"   },
    ].map((item, i) => (
      <>
        {i > 0 && <div class="w-px h-8 bg-blue-400/20"></div>}
        <div class="text-center">
          <p id={item.id} class="font-[Cormorant_Garamond] text-blue-950 leading-none min-w-[2ch] text-center" style="font-size:2.2rem;">--</p>
          <p class="font-[Jost] text-[0.55rem] tracking-[0.2em] uppercase text-blue-950/45 mt-1">{item.label}</p>
        </div>
      </>
    ))}
  </div>

  <!-- Scroll hint -->
  <div class="hero-item flex flex-col items-center gap-2 mt-12">
    <span class="font-[Jost] text-[0.55rem] tracking-[0.25em] uppercase text-blue-950/35">Descubre más</span>
    <div id="scroll-arrow" class="w-px h-8" style="background: linear-gradient(to bottom, rgba(74,122,181,0.5), transparent);"></div>
  </div>

</section>

<style>
  .hero-item {
    opacity: 0;
    transform: translateY(24px);
    animation: heroFade 0.9s ease forwards;
  }
  .hero-item:nth-child(1) { animation-delay: 0.10s; }
  .hero-item:nth-child(2) { animation-delay: 0.25s; }
  .hero-item:nth-child(3) { animation-delay: 0.45s; }
  .hero-item:nth-child(4) { animation-delay: 0.65s; }
  .hero-item:nth-child(5) { animation-delay: 0.85s; }
  .hero-item:nth-child(6) { animation-delay: 1.00s; }

  @keyframes heroFade {
    to { opacity: 1; transform: translateY(0); }
  }

  #scroll-arrow {
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1);   }
    50%       { opacity: 1;   transform: scaleY(1.3); }
  }
</style>

<script define:vars={{ hora }}>
  const bodaDate = new Date(hora);

  function update() {
    const diff = bodaDate.getTime() - Date.now();

    if (diff <= 0) {
      document.getElementById('cd-dias').textContent  = '¡Hoy!';
      document.getElementById('cd-horas').textContent = '--';
      document.getElementById('cd-min').textContent   = '--';
      document.getElementById('cd-seg').textContent   = '--';
      return;
    }

    document.getElementById('cd-dias').textContent  = String(Math.floor(diff / 86400000));
    document.getElementById('cd-horas').textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2,'0');
    document.getElementById('cd-min').textContent   = String(Math.floor((diff % 3600000)  / 60000)).padStart(2,'0');
    document.getElementById('cd-seg').textContent   = String(Math.floor((diff % 60000)    / 1000)).padStart(2,'0');
  }

  update();
  setInterval(update, 1000);
</script>