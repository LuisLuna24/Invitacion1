---

<section id="ubicacion" class="w-full pb-28 px-6 bg-[#f0f4fa] flex flex-col items-center gap-16 relative overflow-hidden">

  <!-- Decorativos -->
  <svg class="absolute top-0 left-0 w-64 opacity-5 pointer-events-none" viewBox="0 0 200 200" fill="none">
    <circle cx="0" cy="0" r="80"  stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="0" r="120" stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="0" r="160" stroke="#4a7ab5" stroke-width="1"/>
  </svg>
  <svg class="absolute bottom-0 right-0 w-64 opacity-5 rotate-180 pointer-events-none" viewBox="0 0 200 200" fill="none">
    <circle cx="0" cy="0" r="80"  stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="0" r="120" stroke="#4a7ab5" stroke-width="1"/>
    <circle cx="0" cy="0" r="160" stroke="#4a7ab5" stroke-width="1"/>
  </svg>

  <!-- Header -->
  <div class="ubi-item flex flex-col items-center gap-4 text-center relative z-10">
    <div class="flex items-center gap-4">
      <div class="w-9 h-px bg-blue-400/35"></div>
      <span class="font-[Jost] text-[0.58rem] tracking-[0.35em] uppercase text-blue-950/40">Nos vemos aquí</span>
      <div class="w-9 h-px bg-blue-400/35"></div>
    </div>
    <h2 class="font-[Cormorant_Garamond] text-[clamp(2rem,5vw,3rem)] italic text-blue-950 font-normal leading-tight">
      Lugar & Horarios
    </h2>
  </div>

  <!-- Línea de tiempo -->
  <div class="ubi-item relative z-10 w-full max-w-3xl flex flex-col gap-0">
    {lugares.map((lugar, i) => (
      <div class="lugar-card flex gap-6 group">

        <!-- Timeline -->
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 rounded-full bg-white border-2 border-blue-400/40 flex items-center justify-center shrink-0 group-hover:border-blue-500 group-hover:bg-blue-50 transition-all duration-300 z-10 p-1.5">
            <Fragment set:html={iconos[lugar.icono ?? 'iglesia']} />
          </div>
          {i < lugares.length - 1 && (
            <div class="w-px flex-1 bg-blue-200/50 my-1 min-h-[3rem]"></div>
          )}
        </div>

        <!-- Card -->
        <div class="pb-10 flex-1">
          <div class="bg-white border border-blue-100/80 rounded p-6 flex flex-col gap-4 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">

            <!-- Tipo + hora -->
            <div class="flex items-center justify-between flex-wrap gap-2">
              <span class="font-[Jost] text-[0.55rem] tracking-[0.3em] uppercase text-blue-500 font-medium">
                {lugar.tipo}
              </span>
              <span class="font-[Jost] text-[0.6rem] tracking-[0.15em] text-blue-950/40 bg-blue-50 px-3 py-1 rounded-full border border-blue-100">
                {lugar.hora}
              </span>
            </div>

            <!-- Nombre -->
            <h3 class="font-[Cormorant_Garamond] text-xl md:text-2xl italic text-blue-950 font-normal leading-snug">
              {lugar.nombre}
            </h3>

            <!-- Dirección -->
            {lugar.direccion && (
              <p class="font-[Jost] text-xs text-blue-950/50 leading-relaxed">
                {lugar.direccion}
              </p>
            )}

            <!-- Descripción -->
            {lugar.descripcion && (
              <p class="font-[Cormorant_Garamond] text-base italic text-blue-950/60 leading-relaxed border-l-2 border-blue-200 pl-3">
                {lugar.descripcion}
              </p>
            )}

            <!-- Botón mapa -->
            {lugar.mapaUrl && (
              
                <a href={lugar.mapaUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="self-start flex items-center gap-2 px-4 py-2 text-[0.6rem] font-[Jost] tracking-[0.2em] uppercase text-white bg-blue-950 rounded hover:bg-blue-500 transition-colors duration-300 mt-1"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Ver en Google Maps
              </a>
            )}
          </div>
        </div>

      </div>
    ))}
  </div>

</section>

<style>
  .ubi-item, .lugar-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .ubi-item.visible, .lugar-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const ubiEls = document.querySelectorAll('.ubi-item, .lugar-card');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 120);
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  ubiEls.forEach(el => obs.observe(el));
</script>