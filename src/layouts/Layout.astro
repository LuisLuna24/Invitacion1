---
import '../styles/global.css'

// 1. Interfaces escalables para personalizar todo desde fuera
interface NavLink {
    name: string;
    href: string;
    isRsvp?: boolean;
}

interface Props {
    title?: string;
    nombres?: string;
    hashtag?: string;
    musicSrc?: string;
    fraseFooter?: string;
    navLinks?: NavLink[];
    mensajesLoader?: string[];
}

const { 
    title = "¡Nos Casamos! - Nuestra Boda",
    nombres = "Viridiana & Alexis",
    hashtag = "#ViridianayAlexis",
    musicSrc = "/music/song.mp3",
    fraseFooter = "¡Acompáñanos en nuestro gran día!",
    navLinks = [
        { name: "Detalles", href: "#detalles" },
        { name: "Ubicación", href: "#ubicacion" },
        { name: "Galería", href: "#collage" },
        { name: "RSVP", href: "#asistencia", isRsvp: true }
    ],
    mensajesLoader = [
        "Dos almas se conocen, se enamoran,",
        "se eligen y se unen, siendo su destino una aventura inolvidable;",
        "Nos casaremos, construyendo nuestra relación sobre los pilares:",
        "AMOR, RESPETO, CONFIANZA Y COMPROMISO."
    ]
} = Astro.props;

// Dividimos el arreglo de links para el header de escritorio
const half = Math.ceil(navLinks.length / 2);
const leftLinks = navLinks.slice(0, half);
const rightLinks = navLinks.slice(half);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    
    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
    
    <!-- GSAP via CDN (También puedes instalarlo via npm instal gsap) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>

    <style>
        /* Mantenemos clases tipográficas y animaciones clave muy específicas aquí */
        .font-cormorant { font-family: 'Cormorant Garamond', serif; }
        .font-jost { font-family: 'Jost', sans-serif; }
        
        .loader-line {
            background: linear-gradient(90deg, transparent, #4a7ab5, transparent);
        }

        /* ── Pétalos: Todo el estilo está aquí, no en JS ── */
        .petal {
            position: absolute;
            width: 6px;
            height: 10px;
            background: radial-gradient(ellipse, #b8d0e8 0%, transparent 70%);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            opacity: 0; /* Inicialmente ocultos */
            animation: fall linear infinite; /* Animación definida aquí */
        }

        @keyframes fall {
            0%   { transform: translateY(-20px) rotate(0deg);   opacity: 0; }
            10%  { opacity: 0.6; } /* Visible aquí por la animación */
            90%  { opacity: 0.3; }
            100% { transform: translateY(100vh) rotate(360deg); opacity: 0; }
        }

        .music-waves span {
            animation: wave 0.8s ease-in-out infinite alternate;
        }
        .music-waves span:nth-child(1) { height: 8px;  animation-delay: 0s; }
        .music-waves span:nth-child(2) { height: 14px; animation-delay: 0.15s; }
        .music-waves span:nth-child(3) { height: 10px; animation-delay: 0.3s; }
        .music-waves span:nth-child(4) { height: 16px; animation-delay: 0.45s; }
        .music-waves span:nth-child(5) { height: 6px;  animation-delay: 0.6s; }
        .paused span { animation-play-state: paused; }

        @keyframes wave {
            from { transform: scaleY(0.4); }
            to   { transform: scaleY(1); }
        }
    </style>
</head>

<body class="w-full min-h-screen flex flex-col items-stretch overflow-x-hidden bg-[#f0f4fa] text-[#1a2a40] font-jost antialiased">

    <!-- ═══ LOADER ═══════════════════════════════════════ -->
    <div id="loader" class="fixed inset-0 z-[9999] bg-[#0a1628] flex flex-col items-center justify-center gap-8">
        <div class="absolute inset-0 overflow-hidden pointer-events-none" id="petals-container"></div>
        
        <!-- Elementos ocultos inicialmente para GSAP -->
        <div class="gsap-names opacity-0 translate-y-5 font-cormorant text-[clamp(2.5rem,8vw,5rem)] italic text-[#7aaad4] tracking-wider text-center">
            {nombres}
        </div>
        
        <div class="gsap-line w-0 h-px loader-line"></div>
        
        <div class="flex flex-col gap-2">
            {mensajesLoader.map((msg) => (
                <p class="gsap-sub opacity-0 translate-y-3 font-jost text-[0.65rem] tracking-[0.35em] uppercase text-[#7aaad4] text-center">
                    {msg}
                </p>
            ))}
        </div>

        <button id="enter-btn" class="gsap-btn opacity-0 mt-6 px-10 py-3 font-jost text-[0.65rem] tracking-[0.3em] uppercase bg-transparent border border-[#4a7ab5] text-[#7aaad4] rounded hover:bg-[#4a7ab5] hover:text-[#0a1628] transition-colors duration-300">
            Entrar
        </button>
    </div>

    <!-- ═══ AUDIO ════════════════════════════════════════ -->
    <audio id="bg-music" loop preload="auto">
        <source src={musicSrc} type="audio/mpeg">
    </audio>

    <!-- ═══ HEADER ═══════════════════════════════════════ -->
    <header class="fixed top-0 w-full z-50 bg-[#f0f4fa]/95 backdrop-blur-md border-b border-[#4a7ab5]/20">
        <div class="w-full max-w-7xl mx-auto px-6 h-20 flex items-center justify-center lg:justify-between relative">

            <!-- Nav Desktop Izquierda -->
            <nav class="hidden lg:flex absolute left-8 gap-10">
                {leftLinks.map(link => (
                    <a href={link.href} class="font-jost text-[0.65rem] tracking-[0.25em] uppercase text-[#0d2448]/55 hover:text-[#4a7ab5] transition-colors">
                        {link.name}
                    </a>
                ))}
            </nav>

            <!-- Logo Central -->
            <a href="/" class="absolute left-1/2 -translate-x-1/2 font-cormorant text-[clamp(1.6rem,4vw,2.6rem)] italic text-[#0d2448] no-underline tracking-wide whitespace-nowrap">
                {nombres.split('&').map((n, i) => (
                    <>
                        {i > 0 && <span class="text-[#4a7ab5]"> & </span>}
                        {n.trim()}
                    </>
                ))}
            </a>

            <!-- Nav Desktop Derecha -->
            <nav class="hidden lg:flex absolute right-8 gap-10">
                {rightLinks.map(link => (
                    <a href={link.href} class={`font-jost text-[0.65rem] tracking-[0.25em] uppercase transition-colors ${link.isRsvp ? 'text-[#4a7ab5] font-medium' : 'text-[#0d2448]/55 hover:text-[#4a7ab5]'}`}>
                        {link.name}
                    </a>
                ))}
            </nav>

            <!-- Botón Menú Móvil -->
            <button id="menu-btn" class="lg:hidden absolute right-4 p-2 text-[#0d2448]" aria-label="Menú">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-7 h-7">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>

        </div>
    </header>

    <!-- ═══ MENÚ MÓVIL ═══════════════════════════════════ -->
    <div id="mobile-menu" class="fixed top-20 left-0 w-full bg-[#f0f4fa]/98 backdrop-blur-md border-b border-[#4a7ab5]/20 flex flex-col items-center z-[49] overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out">
        <div class="flex flex-col w-full py-2">
            {navLinks.map(link => (
                <a href={link.href} class={`mobile-link w-full text-center py-4 font-jost text-[0.65rem] tracking-[0.25em] uppercase transition-colors ${link.isRsvp ? 'text-[#4a7ab5] font-medium' : 'text-[#0d2448]/60 hover:text-[#4a7ab5]'}`}>
                    {link.name}
                </a>
            ))}
        </div>
    </div>

    <!-- ═══ MAIN ══════════════════════════════════════════ -->
    <main class="flex-1 w-full flex flex-col items-center mt-20">
        <slot />
    </main>

    <!-- ═══ FOOTER ═══════════════════════════════════════ -->
    <footer class="w-full bg-[#0a1628] border-t border-[#4a7ab5]/15 py-20 px-4 text-center">
        <div class="max-w-7xl mx-auto flex flex-col items-center gap-5">
            <p class="font-cormorant text-3xl italic text-[#7aaad4]">{fraseFooter}</p>
            <div class="w-16 h-px bg-[#4a7ab5]/40"></div>
            <p class="font-jost text-[0.6rem] tracking-[0.3em] uppercase text-[#7aaad4]/70">{hashtag}</p>
        </div>
    </footer>

    <!-- ═══ MUSIC BTN ════════════════════════════════════ -->
    <button id="music-btn" class="fixed bottom-8 right-8 w-14 h-14 rounded-full bg-[#0a1628] border border-[#4a7ab5] text-[#7aaad4] flex items-center justify-center z-[100] shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:scale-110 hover:bg-[#4a7ab5] hover:text-[#f0f4fa] transition-all duration-300" aria-label="Música">
        <div class="music-waves paused flex gap-[2px] items-center" id="music-waves">
            <span class="block w-[3px] bg-current rounded-sm"></span>
            <span class="block w-[3px] bg-current rounded-sm"></span>
            <span class="block w-[3px] bg-current rounded-sm"></span>
            <span class="block w-[3px] bg-current rounded-sm"></span>
            <span class="block w-[3px] bg-current rounded-sm"></span>
        </div>
    </button>

    <script>
        // Declaramos globalmente para typescript en el bloque de Astro
        declare const gsap: any;

        document.addEventListener("DOMContentLoaded", () => {
            // ── Generar Pétalos (CORREGIDO) ────────────────────────
            const container = document.getElementById('petals-container');
            if(container) {
                for (let i = 0; i < 25; i++) {
                    const p = document.createElement('div');
                    
                    // CORRECCIÓN: Usamos solo la clase .petal. No añadimos ninguna clase de Tailwind de opacidad
                    p.className = 'petal'; 
                    
                    p.style.left = `${Math.random() * 100}%`;
                    p.style.animationDuration = `${3 + Math.random() * 4}s`;
                    p.style.animationDelay = `${Math.random() * 3}s`;
                    p.style.transform = `rotate(${Math.random() * 360}deg) scale(${0.5 + Math.random()})`;
                    container.appendChild(p);
                }
            }

            // ── Animación Inicial GSAP ──────────────────────────────
            const tl = gsap.timeline();
            
            tl.to(".gsap-names", { opacity: 1, y: 0, duration: 1.2, ease: "power3.out", delay: 0.2 })
              .to(".gsap-line", { width: "200px", duration: 1.2, ease: "power3.inOut" }, "-=0.6")
              .to(".gsap-sub", { opacity: 1, y: 0, duration: 0.8, stagger: 0.15, ease: "power2.out" }, "-=0.4")
              .to(".gsap-btn", { opacity: 1, duration: 1 }, "+=0.2");

            // ── Botón "Entrar" y Audio ──────────────────────────────
            const enterBtn = document.getElementById('enter-btn');
            const loader = document.getElementById('loader');
            const audio = document.getElementById('bg-music') as HTMLAudioElement;
            const musicBtn = document.getElementById('music-btn');
            const waves = document.getElementById('music-waves');
            let playing = false;

            if(enterBtn && loader && audio && waves) {
                enterBtn.addEventListener('click', () => {
                    // Desvanecer el loader con GSAP
                    gsap.to(loader, { 
                        opacity: 0, 
                        duration: 0.8, 
                        ease: "power2.inOut",
                        onComplete: () => { loader.style.display = 'none'; } 
                    });

                    // Iniciar Audio
                    audio.volume = 0;
                    audio.play().then(() => {
                        playing = true;
                        waves.classList.remove('paused');
                        
                        // Fade in de volumen nativo
                        let vol = 0;
                        const fade = setInterval(() => {
                            vol = Math.min(vol + 0.02, 0.6);
                            audio.volume = vol;
                            if (vol >= 0.6) clearInterval(fade);
                        }, 80);
                    }).catch(() => console.log("Interacción de audio requerida"));
                });
            }

            if(musicBtn && audio && waves) {
                musicBtn.addEventListener('click', () => {
                    if (playing) {
                        audio.pause(); 
                        playing = false; 
                        waves.classList.add('paused');
                    } else {
                        audio.play(); 
                        playing = true; 
                        waves.classList.remove('paused');
                    }
                });
            }

            // ── Menú Móvil Toggle ──────────────────────────────────
            const menuBtn = document.getElementById('menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            const mobileLinks = document.querySelectorAll('.mobile-link');
            let menuOpen = false;

            if(menuBtn && mobileMenu) {
                const toggleMenu = () => {
                    menuOpen = !menuOpen;
                    if (menuOpen) {
                        mobileMenu.classList.remove('max-h-0', 'opacity-0');
                        mobileMenu.classList.add('max-h-[400px]', 'opacity-100');
                    } else {
                        mobileMenu.classList.remove('max-h-[400px]', 'opacity-100');
                        mobileMenu.classList.add('max-h-0', 'opacity-0');
                    }
                };

                menuBtn.addEventListener('click', toggleMenu);
                
                // Cerrar menú al hacer click en un enlace
                mobileLinks.forEach(link => {
                    link.addEventListener('click', () => {
                        if(menuOpen) toggleMenu();
                    });
                });
            }
        });
    </script>
</body>
</html>